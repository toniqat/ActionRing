{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/**/*",
    "shared/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "paths": {
      "@ring/*": ["src/renderer/ring/src/*"],
      "@settings/*": ["src/renderer/settings/src/*"],
      "@shared/*": ["shared/*"]
    }
  }
}
